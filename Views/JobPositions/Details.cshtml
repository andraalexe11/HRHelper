@model HRHelper.Models.JobPosition

@{
    ViewData["Title"] = Model.Title;
}

<div class="container pb-5">
    <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small mb-4 d-inline-block">
        ←Dashboard
    </a>

    <div class="details-container">
        <div class="job-header-badge @(Model.Department == "IT" ? "bg-dark text-white" : "bg-danger text-white")">
            @Model.Department
        </div>

        <h1 class="title-large">@Model.Title</h1>

        <div class="mb-5">
            <span class="section-label">Description</span>
            <p class="content-text">@Model.Description</p>
        </div>

        <div class="info-grid">
            <div>
                <span class="section-label">Must Have</span>
                <p class="content-text" style="font-size: 1rem;">@Model.MustHave</p>
            </div>
            <div>
                <span class="section-label">Tehnologies</span>
                <p class="content-text" style="font-size: 1rem;">@Model.Technologies</p>
            </div>
        </div>

        <hr class="my-5 opacity-25">

        <div class="mb-5">
            <span class="section-label">Interview Guide</span>
            <p class="content-text">@Model.InterviewGuide</p>
        </div>
        @if (!string.IsNullOrEmpty(Model.LearningMaterial))
        {
            <div class="mt-5 p-4 bg-white rounded-4 shadow-sm border-start border-danger border-5">
                <span class="section-label mb-3 d-block">Learning Resources</span>
        
                <partial name="@("~/Views/Shared/LearningMaterials/_" + Model.LearningMaterial + ".cshtml")" />
            </div>
        }
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <div class="text-muted small border-top pt-3 mb-4">
                <div>
                    Created @Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    @if (!string.IsNullOrEmpty(Model.CreatedByEmail))
                    {
                        <span>by <strong>@Model.CreatedByEmail</strong></span>
                    }
                </div>
                @if (Model.UpdatedAt.HasValue)
                {
                    <div>
                        Last edited @Model.UpdatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        @if (!string.IsNullOrEmpty(Model.UpdatedByEmail))
                        {
                            <span>by <strong>@Model.UpdatedByEmail</strong></span>
                        }
                    </div>
                }
            </div>
        }

        <div class="text-center mt-5">
            @if (Model.QuestionCount >= 5)
            {
                <a asp-controller="Quiz" asp-action="Start" asp-route-jobPositionId="@Model.Id"
                   class="btn-luxury-red px-5 py-3 fs-5 text-decoration-none d-inline-block shadow">
                    Test your Knowledge
                </a>
            }
            else
            {
                <button type="button"
                        class="btn-luxury-red px-5 py-3 fs-5 d-inline-block shadow disabled"
                        style="opacity: 0.55; cursor: not-allowed;"
                        data-bs-toggle="tooltip"
                        title="Quiz not available yet">
                    Test your Knowledge
                </button>
                <div class="text-muted small mt-2">Quiz not available yet — needs at least 5 questions.</div>
            }

            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
                <div class="mt-4 d-flex justify-content-center gap-3 flex-wrap">
                    <a asp-controller="Questions" asp-action="Index" asp-route-jobPositionId="@Model.Id"
                       class="btn btn-outline-danger btn-sm px-3">Manage Questions</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-outline-danger btn-sm px-3">Edit Position</a>
                </div>
            }
        </div>
    </div>
</div>