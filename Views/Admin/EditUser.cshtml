@model HRHelper.Models.EditUserViewModel

@{
    ViewData["Title"] = "Edit User";
    var tempPwd = TempData["TempPassword"] as string;
    var tempPwdEmail = TempData["TempPasswordEmail"] as string;
    var tempPwdReason = TempData["TempPasswordReason"] as string;
    var status = TempData["StatusMessage"] as string;
}

<div class="container pb-5">
    <a asp-controller="Admin" asp-action="Users" class="text-muted text-decoration-none small mb-4 d-inline-block">
        ← Back to users
    </a>

    <div class="row justify-content-center">
        <div class="col-lg-6">

            @if (!string.IsNullOrEmpty(tempPwd))
            {
                <div class="alert alert-warning mb-4" role="alert">
                    <strong>@tempPwdReason for @tempPwdEmail.</strong>
                    Save this password — it will not be shown again:
                    <code class="ms-2 px-2 py-1 bg-light fs-6">@tempPwd</code>
                </div>
            }

            @if (!string.IsNullOrEmpty(status))
            {
                <div class="alert alert-info mb-4">@status</div>
            }

            <div class="login-card">
                <div class="text-center mb-4">
                    <span class="section-label">Administration</span>
                    <h2 class="fw-bold">Edit User</h2>
                    <p class="text-muted small mb-0">@Model.Email @(Model.IsSelf ? "(you)" : "")</p>
                    <p class="text-muted small mb-0">Created @Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
                </div>

                <form asp-controller="Admin" asp-action="EditUser" asp-route-id="@Model.Id" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label small fw-bold text-secondary">Full Name</label>
                        <input asp-for="FullName" class="form-control luxury-input" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label small fw-bold text-secondary">Role</label>
                        <select asp-for="Role" class="form-select luxury-input" disabled="@Model.IsSelf">
                            @foreach (var r in Model.AllRoles)
                            {
                                <option value="@r">@r</option>
                            }
                        </select>
                        @if (Model.IsSelf)
                        {
                            <input type="hidden" asp-for="Role" />
                            <div class="text-muted small mt-1">You cannot change your own role.</div>
                        }
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox"
                               disabled="@Model.IsSelf" />
                        <label asp-for="IsActive" class="form-check-label small fw-bold text-secondary">Active</label>
                        @if (Model.IsSelf)
                        {
                            <input type="hidden" asp-for="IsActive" />
                            <div class="text-muted small mt-1">You cannot deactivate your own account.</div>
                        }
                    </div>

                    <div class="pt-2 d-grid gap-2">
                        <button type="submit" class="btn-luxury-red py-3">Save Changes</button>
                    </div>
                </form>

                <hr class="my-4" />

                <form asp-controller="Admin" asp-action="ResetPassword" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Generate a new temporary password? The old password will stop working immediately.');">
                    @Html.AntiForgeryToken()
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong class="small">Reset password</strong>
                            <div class="text-muted small">Generate a new temporary password.</div>
                        </div>
                        <button type="submit" class="btn btn-outline-danger btn-sm">Reset Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
