@model HRHelper.Models.UserListViewModel

@{
    ViewData["Title"] = "Users";
    var status = TempData["StatusMessage"] as string;
    var tempPwd = TempData["TempPassword"] as string;
    var tempPwdEmail = TempData["TempPasswordEmail"] as string;
    var tempPwdReason = TempData["TempPasswordReason"] as string;
}

<div class="container pb-5">
    <div class="d-flex flex-wrap justify-content-between align-items-end mb-4">
        <div>
            <span class="section-label">Administration</span>
            <h2 class="fw-bold mb-1">Users</h2>
            <p class="text-muted small mb-0">@Model.TotalCount user@(Model.TotalCount == 1 ? "" : "s") in total</p>
        </div>
        <a asp-controller="Admin" asp-action="CreateUser" class="btn-luxury-red px-4 py-2 text-decoration-none">
            + New User
        </a>
    </div>

    @if (!string.IsNullOrEmpty(tempPwd))
    {
        <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
            <div class="flex-grow-1">
                <strong>@tempPwdReason for @tempPwdEmail.</strong>
                Save this password — it will not be shown again:
                <code class="ms-2 px-2 py-1 bg-light fs-6">@tempPwd</code>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(status))
    {
        <div class="alert alert-info mb-4">@status</div>
    }

    <form method="get" class="row g-3 mb-4 align-items-end">
        <div class="col-md-4">
            <label class="form-label small fw-bold text-secondary">Search</label>
            <input type="text" name="q" value="@Model.Q" class="form-control luxury-input" placeholder="email or name" />
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold text-secondary">Role</label>
            <select name="role" class="form-select luxury-input">
                <option value="">All roles</option>
                @foreach (var r in Model.AllRoles)
                {
                    <option value="@r" selected="@(Model.Role == r)">@r</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold text-secondary">Status</label>
            <select name="status" class="form-select luxury-input">
                <option value="all" selected="@(Model.Status == "all")">All</option>
                <option value="active" selected="@(Model.Status == "active")">Active</option>
                <option value="inactive" selected="@(Model.Status == "inactive")">Inactive</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-danger w-100">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table align-middle">
            <thead class="text-secondary small text-uppercase">
                <tr>
                    <th>Email</th>
                    <th>Name</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr>
                        <td class="fw-semibold">
                            @u.Email
                            @if (u.IsSelf)
                            {
                                <span class="badge bg-secondary ms-2 small">you</span>
                            }
                        </td>
                        <td class="text-muted">@(string.IsNullOrEmpty(u.FullName) ? "—" : u.FullName)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(u.Role))
                            {
                                <span class="badge bg-dark">@u.Role</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td class="text-muted small">@u.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@u.Id"
                               class="btn btn-link btn-sm text-secondary text-decoration-none">Edit</a>
                            @if (!u.IsSelf)
                            {
                                <form asp-controller="Admin" asp-action="Delete" asp-route-id="@u.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Deactivate this user?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link btn-sm text-danger text-decoration-none">Deactivate</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (Model.Users.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No users match your filters.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="d-flex justify-content-center mt-4">
            <ul class="pagination">
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link"
                           asp-controller="Admin" asp-action="Users"
                           asp-route-q="@Model.Q"
                           asp-route-role="@Model.Role"
                           asp-route-status="@Model.Status"
                           asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
