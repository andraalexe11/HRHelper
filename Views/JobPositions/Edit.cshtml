@model HRHelper.Models.JobPosition

@{
    ViewData["Title"] = "Edit Position";
}

<div class="container pb-5">
    <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small mb-4 d-inline-block">
        ←Dashboard
    </a>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="login-card">
                <div class="text-center mb-4">
                    <span class="section-label">Content Management</span>
                    <h2 class="fw-bold">Edit Position</h2>
                </div>

                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Title" class="form-label small fw-bold text-secondary">Job Title</label>
                            <input asp-for="Title" class="form-control luxury-input" placeholder="e.g. Java Developer" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="Department" class="form-label small fw-bold text-secondary">Department</label>
                            <select asp-for="Department" class="form-select luxury-input">
                                <option value="IT">IT</option>
                                <option value="HR">HR</option>
                            </select>
                            <span asp-validation-for="Department" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label small fw-bold text-secondary">Description</label>
                        <textarea asp-for="Description" class="form-control luxury-input" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="MustHave" class="form-label small fw-bold text-secondary">Must Have</label>
                            <textarea asp-for="MustHave" class="form-control luxury-input" rows="3"></textarea>
                            <span asp-validation-for="MustHave" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Technologies" class="form-label small fw-bold text-secondary">Technologies</label>
                            <textarea asp-for="Technologies" class="form-control luxury-input" rows="3"></textarea>
                            <span asp-validation-for="Technologies" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="InterviewGuide" class="form-label small fw-bold text-secondary">Interview Guide</label>
                        <textarea asp-for="InterviewGuide" class="form-control luxury-input" rows="3"></textarea>
                        <span asp-validation-for="InterviewGuide" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Jargon" class="form-label small fw-bold text-secondary">Jargon</label>
                        <input asp-for="Jargon" class="form-control luxury-input" placeholder="e.g. API, REST, Scrum" />
                        <span asp-validation-for="Jargon" class="text-danger small"></span>
                    </div>

                    <div class="pt-3">
                        <button type="submit" class="btn-luxury-red w-100 py-3">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}