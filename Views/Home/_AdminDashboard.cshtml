@model HRHelper.Models.AdminDashboardVm
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <span class="section-label">System Overview</span>
            <h2 class="fw-bold mb-0">Admin Dashboard</h2>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-danger">Manage Users</a>
        </div>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="login-card text-center py-4">
                <span class="section-label">Users</span>
                <div class="display-4 fw-bold">@Model.TotalUsers</div>
                <div class="small text-muted">
                    @{
                        var admins = Model.UsersByRole.GetValueOrDefault("Admin", 0);
                        var managers = Model.UsersByRole.GetValueOrDefault("Manager", 0);
                        var recruiters = Model.UsersByRole.GetValueOrDefault("Recruiter", 0);
                    }
                    <span class="badge bg-dark me-1">@admins admin@(admins == 1 ? "" : "s")</span>
                    <span class="badge bg-dark me-1">@managers manager@(managers == 1 ? "" : "s")</span>
                    <span class="badge bg-dark">@recruiters recruiter@(recruiters == 1 ? "" : "s")</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="login-card text-center py-4">
                <span class="section-label">Positions</span>
                <div class="display-4 fw-bold">@Model.TotalPositions</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="login-card text-center py-4">
                <span class="section-label">Questions</span>
                <div class="display-4 fw-bold">@Model.TotalQuestions</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="login-card text-center py-4">
                <span class="section-label">Attempts</span>
                <div class="display-4 fw-bold">@Model.TotalAttempts</div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <h3 class="fw-bold mb-0">All Positions</h3>
        <a asp-controller="JobPositions" asp-action="Index" class="text-decoration-none small text-danger fw-bold">Full list →</a>
    </div>

    @if (Model.AllPositions.Count == 0)
    {
        <div class="text-center py-5 border rounded-4 bg-light mb-5">
            <h5 class="text-muted fw-light">No positions yet.</h5>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var p in Model.AllPositions)
            {
                var ready = p.QuestionCount >= 5;
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm job-card-luxury @(p.Department == "IT" ? "card-it-luxury text-white" : "card-hr-luxury text-white")">
                        <div class="card-body d-flex flex-column p-4">
                            <span class="badge mb-2">@p.Department</span>
                            <h3 class="fw-bold">@p.Title</h3>
                            <div class="small mb-3">
                                <span class="badge @(ready ? "bg-light text-success" : "bg-light text-danger") me-1">
                                    @p.QuestionCount question@(p.QuestionCount == 1 ? "" : "s")
                                </span>
                                <span class="badge bg-light text-dark">
                                    @p.AttemptCount attempt@(p.AttemptCount == 1 ? "" : "s")
                                </span>
                            </div>
                            <a href="@Url.Action("Details", "JobPositions", new { id = p.Id })"
                               class="text-white mt-auto text-decoration-none text-center">Details→</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
