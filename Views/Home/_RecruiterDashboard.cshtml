@model HRHelper.Models.RecruiterDashboardVm
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">

    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="login-card text-center py-4">
                <span class="section-label">Total Attempts</span>
                <div class="display-4 fw-bold">@Model.TotalAttempts</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="login-card text-center py-4">
                <span class="section-label">Passed</span>
                <div class="display-4 fw-bold text-success">@Model.PassedCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="login-card text-center py-4">
                <span class="section-label">Pass Rate</span>
                <div class="display-4 fw-bold">@Model.PassRatePercent<span class="fs-3">%</span></div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <h3 class="fw-bold mb-0">Available Positions</h3>
        <span class="text-muted small">@Model.AvailablePositions.Count ready to quiz</span>
    </div>

    @if (Model.AvailablePositions.Count == 0)
    {
        <div class="text-center py-5 border rounded-4 bg-light mb-5">
            <h4 class="text-muted fw-light">No positions ready yet.</h4>
            <p class="text-secondary mb-0">Check back when a manager has added 5+ questions.</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var p in Model.AvailablePositions)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm job-card-luxury @(p.Department == "IT" ? "card-it-luxury text-white" : "card-hr-luxury text-white")">
                        <div class="card-body d-flex flex-column p-4">
                            <span class="badge mb-2">@p.Department</span>
                            <h3 class="fw-bold">@p.Title</h3>
                            <a href="@Url.Action("Details", "JobPositions", new { id = p.Id })"
                               class="text-white mt-auto text-decoration-none text-center">Details→</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
